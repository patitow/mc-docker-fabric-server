# Copia para .env (o .env não vai para o Git).
#
# Token: Cloudflare → My Profile → API Tokens → Create Token
# (template "Edit zone DNS" ou Zone → DNS → Edit na zona patitow.dev).
#
# Depois de preencher: docker compose --profile ddns up -d

CLOUDFLARE_API_TOKEN=
# FQDN(s) a atualizar; vírgula se forem vários.
DDNS_DOMAINS=mine.patitow.dev
